APP_NAME=CarePocket API
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
AUTH_SECRET=change-me-in-production
AUTH_TOKEN_LIFETIME_SECONDS=3600

DATABASE_URL=
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=carepocket
POSTGRES_USER=carepocket
POSTGRES_PASSWORD=carepocket

PGADMIN_DEFAULT_EMAIL=admin@carepocket.com
PGADMIN_DEFAULT_PASSWORD=admin

# Optional: use a single connection string instead of the split variables above.
# DATABASE_URL=postgresql://carepocket:carepocket@localhost:5432/carepocket
